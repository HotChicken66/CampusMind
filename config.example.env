# CampusMind 配置模板 (NoneBot2 .env 格式)

# 环境配置 (Environment)
# prod: 生产环境, dev: 开发环境
ENVIRONMENT=prod
# 是否开启热重载
RELOAD=false

# 网络配置 (Network)
HOST=127.0.0.1
PORT=8080

# 机器人基本信息 (Bot Info)
# 超级用户列表 (QQ号)
SUPERUSERS=["你的QQ号"]
# 机器人昵称
NICKNAME=["CampusMind", "学小服"]
# 命令起始符
COMMAND_START=["/"]

# 日志级别 (Log Level)
LOG_LEVEL=INFO

# 适配器与驱动配置 (Adapters)
# 这里可以添加特定的适配器配置

# LLM 接口配置
# 请前往 https://openrouter.ai/ 获取 API Key
OPENROUTER_API_KEY=your_api_key_here
